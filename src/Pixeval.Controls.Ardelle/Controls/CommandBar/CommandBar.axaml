<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:markupExtensions="clr-namespace:Pixeval.Controls.Ardelle.MarkupExtensions">

    <Design.PreviewWith>
      <Border Padding="20" Width="600" Background="#F4F4F3">
        <StackPanel Spacing="20">
          <CommandBar>
            <CommandBarButton Label="新建" Icon="{markupExtensions:SymbolIcon New}" />
            <CommandBarButton Label="保存" Icon="{markupExtensions:SymbolIcon Save}" />
            <CommandBarSeparator />
            <CommandBarToggleButton Label="加粗" Icon="{markupExtensions:SymbolIcon Save}" />
          </CommandBar>
        </StackPanel>
      </Border>
    </Design.PreviewWith>

    <!-- CommandBarButton ControlTheme -->
    <ControlTheme x:Key="{x:Type CommandBarButton}" TargetType="CommandBarButton">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource DefaultBrutalizationShadowBrush}" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="10,6" />
        <Setter Property="Width" Value="68" />
        <Setter Property="MinHeight" Value="40" />
        <Setter Property="CornerRadius" Value="{StaticResource Pixeval.Radius.Small}" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <ControlTemplate>
                <Border x:Name="PART_Border"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{TemplateBinding CornerRadius}"
                        Padding="{TemplateBinding Padding}">
                    <Border.Transitions>
                        <Transitions>
                            <BrushTransition Property="Background" Duration="0:0:0.1" />
                        </Transitions>
                    </Border.Transitions>
                    <StackPanel x:Name="PART_LayoutRoot"
                                Spacing="4"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                        <ContentPresenter x:Name="PART_IconPresenter"
                                          Content="{TemplateBinding Icon}"
                                          Foreground="{TemplateBinding Foreground}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                        <TextBlock x:Name="PART_Label"
                                   Text="{TemplateBinding Label}"
                                   Foreground="{TemplateBinding Foreground}"
                                   FontSize="11"
                                   FontWeight="Black"
                                   HorizontalAlignment="Center"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </Border>
            </ControlTemplate>
        </Setter>

        <!-- Hover / Pressed states -->
        <Style Selector="^:pointerover /template/ Border#PART_Border">
            <Setter Property="Background" Value="{markupExtensions:ColorToken Name=Primary}" />
            <Setter Property="TextElement.Foreground" Value="White" />
        </Style>
        <Style Selector="^:pressed /template/ Border#PART_Border">
            <Setter Property="Background" Value="{markupExtensions:ColorToken Name=Primary}" />
            <Setter Property="TextElement.Foreground" Value="White" />
            <Setter Property="Opacity" Value="0.8" />
        </Style>

        <!-- Compact state -->
        <Style Selector="^[IsCompact=True]">
            <Setter Property="Width" Value="40" />
        </Style>
        <Style Selector="^[IsCompact=True] /template/ TextBlock#PART_Label">
            <Setter Property="IsVisible" Value="False" />
        </Style>

        <!-- LabelPosition=Right: horizontal layout -->
        <Style Selector="^[LabelPosition=Right]">
            <Setter Property="Width" Value="NaN" />
            <Setter Property="MinWidth" Value="40" />
        </Style>
        <Style Selector="^[LabelPosition=Right] /template/ StackPanel#PART_LayoutRoot">
            <Setter Property="Orientation" Value="Horizontal" />
            <Setter Property="Spacing" Value="6" />
        </Style>
        <Style Selector="^[LabelPosition=Right] /template/ ContentPresenter#PART_IconPresenter">
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style Selector="^[LabelPosition=Right] /template/ TextBlock#PART_Label">
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <!-- IsInOverflow: full-width popup layout -->
        <Style Selector="^[IsInOverflow=True]">
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Width" Value="NaN" />
            <Setter Property="MinHeight" Value="36" />
        </Style>
        <Style Selector="^[IsInOverflow=True] /template/ StackPanel#PART_LayoutRoot">
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="Orientation" Value="Horizontal" />
            <Setter Property="Spacing" Value="0" />
        </Style>
        <Style Selector="^[IsInOverflow=True] /template/ ContentPresenter#PART_IconPresenter">
            <Setter Property="Width" Value="16" />
            <Setter Property="Height" Value="16" />
            <Setter Property="Margin" Value="4,0,10,0" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style Selector="^[IsInOverflow=True] /template/ TextBlock#PART_Label">
            <Setter Property="IsVisible" Value="True" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </ControlTheme>

    <!-- CommandBarToggleButton ControlTheme -->
    <ControlTheme x:Key="{x:Type CommandBarToggleButton}" TargetType="CommandBarToggleButton">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource DefaultBrutalizationShadowBrush}" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="10,6" />
        <Setter Property="Width" Value="68" />
        <Setter Property="MinHeight" Value="40" />
        <Setter Property="CornerRadius" Value="{StaticResource Pixeval.Radius.Small}" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <ControlTemplate>
                <Border x:Name="PART_Border"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{TemplateBinding CornerRadius}"
                        Padding="{TemplateBinding Padding}">
                    <Border.Transitions>
                        <Transitions>
                            <BrushTransition Property="Background" Duration="0:0:0.1" />
                        </Transitions>
                    </Border.Transitions>
                    <StackPanel x:Name="PART_LayoutRoot"
                                Spacing="4"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                        <ContentPresenter x:Name="PART_IconPresenter"
                                          Content="{TemplateBinding Icon}"
                                          Foreground="{TemplateBinding Foreground}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                        <TextBlock x:Name="PART_Label"
                                   Text="{TemplateBinding Label}"
                                   Foreground="{TemplateBinding Foreground}"
                                   FontSize="11"
                                   FontWeight="Black"
                                   HorizontalAlignment="Center"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </Border>
            </ControlTemplate>
        </Setter>

        <!-- Hover / Pressed states -->
        <Style Selector="^:pointerover /template/ Border#PART_Border">
            <Setter Property="Background" Value="{markupExtensions:ColorToken Name=Primary}" />
            <Setter Property="Opacity" Value="0.15" />
        </Style>
        <Style Selector="^:pressed /template/ Border#PART_Border">
            <Setter Property="Background" Value="{markupExtensions:ColorToken Name=Primary}" />
            <Setter Property="Opacity" Value="0.3" />
        </Style>

        <!-- Checked State -->
        <Style Selector="^:checked /template/ Border#PART_Border">
            <Setter Property="Background" Value="{markupExtensions:ColorToken Name=Secondary}" />
            <Setter Property="TextElement.Foreground" Value="White" />
        </Style>
        <Style Selector="^:checked:pointerover /template/ Border#PART_Border">
            <Setter Property="Background" Value="{markupExtensions:ColorToken Name=Secondary}" />
            <Setter Property="TextElement.Foreground" Value="White" />
            <Setter Property="Opacity" Value="0.9" />
        </Style>

        <!-- Compact, LabelPosition=Right, IsInOverflow inherits standard logic -->
        <Style Selector="^[IsCompact=True]">
            <Setter Property="Width" Value="40" />
        </Style>
        <Style Selector="^[IsCompact=True] /template/ TextBlock#PART_Label">
            <Setter Property="IsVisible" Value="False" />
        </Style>

        <Style Selector="^[LabelPosition=Right]">
            <Setter Property="Width" Value="NaN" />
            <Setter Property="MinWidth" Value="40" />
        </Style>
        <Style Selector="^[LabelPosition=Right] /template/ StackPanel#PART_LayoutRoot">
            <Setter Property="Orientation" Value="Horizontal" />
            <Setter Property="Spacing" Value="6" />
        </Style>
        <Style Selector="^[LabelPosition=Right] /template/ ContentPresenter#PART_IconPresenter">
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style Selector="^[LabelPosition=Right] /template/ TextBlock#PART_Label">
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style Selector="^[IsInOverflow=True]">
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Width" Value="NaN" />
            <Setter Property="MinHeight" Value="36" />
        </Style>
        <Style Selector="^[IsInOverflow=True] /template/ StackPanel#PART_LayoutRoot">
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="Orientation" Value="Horizontal" />
            <Setter Property="Spacing" Value="0" />
        </Style>
        <Style Selector="^[IsInOverflow=True] /template/ ContentPresenter#PART_IconPresenter">
            <Setter Property="Width" Value="16" />
            <Setter Property="Height" Value="16" />
            <Setter Property="Margin" Value="4,0,10,0" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style Selector="^[IsInOverflow=True] /template/ TextBlock#PART_Label">
            <Setter Property="IsVisible" Value="True" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </ControlTheme>

    <!-- CommandBarSeparator ControlTheme -->
    <ControlTheme x:Key="{x:Type CommandBarSeparator}" TargetType="CommandBarSeparator">
        <Setter Property="Width" Value="2" />
        <Setter Property="MinHeight" Value="22" />
        <Setter Property="Margin" Value="8,4" />
        <Setter Property="Template">
            <ControlTemplate>
                <Border Background="{StaticResource DefaultBrutalizationShadowBrush}"
                        Width="{TemplateBinding Width}"
                        Height="{TemplateBinding Height}"
                        MinHeight="{TemplateBinding MinHeight}" />
            </ControlTemplate>
        </Setter>

        <Style Selector="^[IsInOverflow=True]">
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="Width" Value="NaN" />
            <Setter Property="Height" Value="2" />
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="Margin" Value="4,6" />
        </Style>
    </ControlTheme>

    <!-- CommandBar ControlTheme -->
    <ControlTheme x:Key="{x:Type CommandBar}" TargetType="CommandBar">
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="Background" Value="White" />
        <Setter Property="BorderBrush" Value="{StaticResource DefaultBrutalizationShadowBrush}" />
        <Setter Property="BorderThickness" Value="2" />
        <Setter Property="CornerRadius" Value="{StaticResource Pixeval.Radius.Medium}" />
        <Setter Property="MinHeight" Value="48" />
        <Setter Property="Padding" Value="4,0" />
        <Setter Property="ItemWidthBottom" Value="70" />
        <Setter Property="ItemWidthRight" Value="102" />
        <Setter Property="ItemWidthCollapsed" Value="42" />
        <Setter Property="Template">
            <ControlTemplate>
                <Grid Background="Transparent">
                    <Panel Margin="0,0,4,4">
                        <!-- Neobrutalism shadow block for command bar -->
                        <Border
                            Background="{StaticResource DefaultBrutalizationShadowBrush}"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            Margin="4,4,0,0" />

                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{TemplateBinding CornerRadius}"
                                Padding="{TemplateBinding Padding}"
                                MinHeight="{TemplateBinding MinHeight}"
                                Margin="0,0,4,4">
                            <Panel>
                                <DockPanel KeyboardNavigation.TabNavigation="Cycle">
                                    <!-- Overflow button (docked right) -->
                                    <Button x:Name="PART_OverflowButton"
                                            DockPanel.Dock="Right"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Padding="12,0"
                                            MinWidth="40"
                                            VerticalAlignment="Stretch"
                                            Cursor="Hand"
                                            IsVisible="{TemplateBinding IsOverflowButtonVisible}">
                                        <PathIcon Width="16" Height="16"
                                                  Foreground="{StaticResource DefaultBrutalizationShadowBrush}"
                                                  Data="M6,10A2,2 0 0,0 4,12A2,2 0 0,0 6,14A2,2 0 0,0 8,12A2,2 0 0,0 6,10M12,10A2,2 0 0,0 10,12A2,2 0 0,0 12,14A2,2 0 0,0 14,12A2,2 0 0,0 12,10M18,10A2,2 0 0,0 16,12A2,2 0 0,0 18,14A2,2 0 0,0 20,12A2,2 0 0,0 18,10Z" />
                                    </Button>

                                    <!-- Custom content area (docked left) -->
                                    <ContentPresenter x:Name="PART_ContentPresenter"
                                                      Content="{TemplateBinding Content}"
                                                      DockPanel.Dock="Left"
                                                      VerticalAlignment="Center" />

                                    <!-- Primary commands (fills remaining space, right-aligned) -->
                                    <ItemsControl x:Name="PART_PrimaryCommands"
                                                  ItemsSource="{Binding VisiblePrimaryCommands, RelativeSource={RelativeSource TemplatedParent}}"
                                                  HorizontalAlignment="Right"
                                                  VerticalAlignment="Stretch"
                                                  ClipToBounds="True">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal" Spacing="2" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                    </ItemsControl>
                                </DockPanel>

                                <!-- Overflow popup with brutalist drop block -->
                                <Popup x:Name="PART_OverflowPopup"
                                       IsOpen="{TemplateBinding IsOpen, Mode=TwoWay}"
                                        InheritsTransform="True"
                                       PlacementTarget="{Binding #PART_OverflowButton}"
                                       Placement="Bottom"
                                       IsLightDismissEnabled="True">
                                    <Grid Background="Transparent">
                                        <Panel Margin="0,0,4,4">
                                            <!-- Popup Neobrutal Shadow -->
                                            <Border
                                                Background="{StaticResource DefaultBrutalizationShadowBrush}"
                                                CornerRadius="{StaticResource Pixeval.Radius.Small}"
                                                Margin="4,4,0,0" />

                                            <Border Background="White"
                                                    BorderBrush="{StaticResource DefaultBrutalizationShadowBrush}"
                                                    BorderThickness="2"
                                                    CornerRadius="{StaticResource Pixeval.Radius.Small}"
                                                    Padding="4"
                                                    MinWidth="160">
                                                <ItemsControl x:Name="PART_OverflowPresenter"
                                                              ItemsSource="{Binding OverflowItems, RelativeSource={RelativeSource TemplatedParent}}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <StackPanel Spacing="2" />
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                </ItemsControl>
                                            </Border>
                                        </Panel>
                                    </Grid>
                                </Popup>
                            </Panel>
                        </Border>
                    </Panel>
                </Grid>
            </ControlTemplate>
        </Setter>
    </ControlTheme>
</ResourceDictionary>
