<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:system="clr-namespace:System;assembly=System.Runtime">
    <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Default">
            <SolidColorBrush x:Key="DefaultCardBackground">#FFFFFF</SolidColorBrush>
            <SolidColorBrush x:Key="DefaultCardBorderBrush">#1A1918</SolidColorBrush>
        </ResourceDictionary>
        <ResourceDictionary x:Key="Dark">
            <SolidColorBrush x:Key="DefaultCardBackground">#20201E</SolidColorBrush>
            <SolidColorBrush x:Key="DefaultCardBorderBrush">#F4F4F3</SolidColorBrush>
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>
    
    <Thickness x:Key="CardContainerGridMargin">5</Thickness>
    <Thickness x:Key="DefaultCardBorderThickness">2</Thickness>
</ResourceDictionary>
