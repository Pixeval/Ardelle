<ResourceDictionary xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Thickness x:Key="DefaultButtonChromePadding">0,0,4,4</Thickness>
    <Thickness x:Key="DefaultButtonContentMargin">24,14,24,14</Thickness>
    <Thickness x:Key="DefaultOutlineButtonBorderThickness">2</Thickness>
    <x:Double x:Key="DefaultIconButtonIconContentSpacing">10</x:Double>
    <x:Double x:Key="DefaultButtonShadowOffset">4</x:Double>
    <TransformOperations x:Key="DefaultButtonHoverTransform">
        translate(2px, 2px)
    </TransformOperations>
    <TransformOperations x:Key="DefaultButtonPressedTransform">
        translate(4px, 4px)
    </TransformOperations>
</ResourceDictionary>
