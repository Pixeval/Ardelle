<ResourceDictionary xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Thickness x:Key="CardContainerGridMargin">0,0,8,8</Thickness>
    <Thickness x:Key="DefaultCardBorderThickness">2</Thickness>
    <x:Double x:Key="DefaultCardShadowOffset">8</x:Double>
    <TransformOperations x:Key="DefaultCardHoverTransform">
        translate(3px, 3px)
    </TransformOperations>
</ResourceDictionary>
