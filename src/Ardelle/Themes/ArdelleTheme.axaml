<Styles 
    x:Class="Ardelle.Themes.ArdelleTheme"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Styles.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://Ardelle/Themes/Colors.axaml" />
                <ResourceInclude Source="avares://Ardelle/Themes/Corners.axaml" />
                <ResourceInclude Source="avares://Ardelle/Themes/Controls.axaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Styles.Resources>
</Styles>
