<ResourceDictionary xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <CornerRadius x:Key="Ardelle.Radius.None">0</CornerRadius>
    <CornerRadius x:Key="Ardelle.Radius.XSmall">2</CornerRadius>
    <CornerRadius x:Key="Ardelle.Radius.Small">4</CornerRadius>
    <CornerRadius x:Key="Ardelle.Radius.Medium">8</CornerRadius>
    <CornerRadius x:Key="Ardelle.Radius.Large">12</CornerRadius>
    <CornerRadius x:Key="Ardelle.Radius.XLarge">20</CornerRadius>
    <CornerRadius x:Key="Ardelle.Radius.Full">999</CornerRadius>
</ResourceDictionary>
