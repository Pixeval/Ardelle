<Window
    x:Class="Pixeval.Controls.Ardelle.Demo.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:buttons="clr-namespace:Pixeval.Controls.Ardelle.Controls.Buttons;assembly=Pixeval.Controls.Ardelle"
    xmlns:card="clr-namespace:Pixeval.Controls.Ardelle.Controls.Card;assembly=Pixeval.Controls.Ardelle"
    xmlns:attachedProperties="clr-namespace:Pixeval.Controls.Ardelle.AttachedProperties;assembly=Pixeval.Controls.Ardelle"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:markupExtensions="clr-namespace:Pixeval.Controls.Ardelle.MarkupExtensions;assembly=Pixeval.Controls.Ardelle"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    x:CompileBindings="False"
    Title="Pixeval Ardelle Neobrutalism UI Showcase"
    Background="#F4F4F3"
    Width="1200"
    Height="900"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">
    
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="30" Spacing="30">
            
            <!-- Header Banner -->
            <Border 
                Background="{markupExtensions:ColorToken Name=Primary}"
                BorderBrush="#1A1918"
                BorderThickness="3"
                CornerRadius="16"
                Padding="30"
                Margin="0,0,8,8"
                attachedProperties:Brutalization.IsBrutalized="True"
                attachedProperties:Brutalization.BrutalizedShadows="8 8 0 0 #1A1918">
                <StackPanel Spacing="10">
                    <TextBlock 
                        FontSize="36" 
                        FontWeight="Black" 
                        Foreground="White" 
                        Text="Ardelle Neobrutalism + Material Gallery" />
                    <TextBlock 
                        FontSize="16" 
                        FontWeight="SemiBold" 
                        Foreground="White" 
                        Opacity="0.9" 
                        Text="精心呈现的混合设计语言库组件展示，融入高对比度、硬阴影、扁平质感与灵动微动效。" />
                </StackPanel>
            </Border>

            <!-- Grid Layout of Showcase Panels -->
            <UniformGrid Columns="2" HorizontalAlignment="Stretch">
                
                <!-- Section 1: Buttons -->
                <card:Card 
                    Margin="10" 
                    Padding="24"
                    Background="White"
                    attachedProperties:Brutalization.IsBrutalized="True"
                    attachedProperties:Brutalization.BrutalizedShadows="6 6 0 0 #1A1918"
                    CornerRadius="12">
                    <StackPanel Spacing="16">
                        <TextBlock FontSize="20" FontWeight="Black" Foreground="#1A1918" Text="Action &amp; Standard Buttons" />
                        <Separator Height="1" Background="#1A1918" Opacity="0.2" />
                        
                        <WrapPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                            <StackPanel Margin="10" Spacing="12">
                                <TextBlock FontWeight="Bold" FontSize="12" Foreground="#888" Text="NEOBRUTALISM ACTIONS" />
                                <buttons:ActionButton 
                                    Content="Action Push" 
                                    Background="{markupExtensions:ColorToken Name=Primary}"/>
                                <buttons:ActionIconButton 
                                    Content="Save Action" 
                                    Icon="{markupExtensions:SymbolIcon Save}" 
                                    Background="{markupExtensions:ColorToken Name=Secondary}"/>
                            </StackPanel>

                            <StackPanel Margin="10" Spacing="12">
                                <TextBlock FontWeight="Bold" FontSize="12" Foreground="#888" Text="STANDARD / OUTLINE" />
                                <buttons:Button 
                                    Content="Flat Solid" 
                                    Background="{markupExtensions:ColorToken Name=Secondary}" />
                                <buttons:OutlineButton 
                                    Content="Outline Button" />
                                <buttons:GhostButton 
                                    Content="Ghost Button" />
                            </StackPanel>
                        </WrapPanel>
                    </StackPanel>
                </card:Card>

                <!-- Section 2: TabControl & Highlighting Views -->
                <card:Card 
                    Margin="10" 
                    Padding="24"
                    Background="White"
                    attachedProperties:Brutalization.IsBrutalized="True"
                    attachedProperties:Brutalization.BrutalizedShadows="6 6 0 0 #1A1918"
                    CornerRadius="12">
                    <StackPanel Spacing="16">
                        <TextBlock FontSize="20" FontWeight="Black" Foreground="#1A1918" Text="Brutalist File Folder View (TabControl)" />
                        <Separator Height="1" Background="#1A1918" Opacity="0.2" />
                        
                        <TabControl Height="180">
                            <TabItem Header="文件一">
                                <StackPanel Margin="15" Spacing="8">
                                    <TextBlock FontSize="16" FontWeight="Black" Text="极简新现代主义" />
                                    <TextBlock FontSize="13" TextWrapping="Wrap" Text="此选卡经过重写，其页签模仿真实的档案文件夹，在选中时获得富有视觉冲击力的主题高亮色。" />
                                </StackPanel>
                            </TabItem>
                            <TabItem Header="设置二">
                                <StackPanel Margin="15" Spacing="8">
                                    <TextBlock FontSize="16" FontWeight="Black" Text="选项卡 B 界面" />
                                    <TextBlock FontSize="13" TextWrapping="Wrap" Text="任何放置在 TabItem 中的视图都会无缝融合在底下的新布鲁重构卡上。" />
                                </StackPanel>
                            </TabItem>
                            <TabItem Header="已锁定页" IsEnabled="False" />
                        </TabControl>
                    </StackPanel>
                </card:Card>

                <!-- Section 3: Selection controls (CheckBox, Radio, Switch) -->
                <card:Card 
                    Margin="10" 
                    Padding="24"
                    Background="White"
                    attachedProperties:Brutalization.IsBrutalized="True"
                    attachedProperties:Brutalization.BrutalizedShadows="6 6 0 0 #1A1918"
                    CornerRadius="12">
                    <StackPanel Spacing="16">
                        <TextBlock FontSize="20" FontWeight="Black" Foreground="#1A1918" Text="Selection Controls" />
                        <Separator Height="1" Background="#1A1918" Opacity="0.2" />
                        
                        <Grid ColumnDefinitions="*,*,*">
                            <!-- CheckBoxes -->
                            <StackPanel Grid.Column="0" Spacing="12">
                                <TextBlock FontWeight="Bold" FontSize="12" Foreground="#888" Text="CHECKBOX" />
                                <CheckBox Content="未选中" />
                                <CheckBox IsChecked="True" Content="选中" />
                                <CheckBox IsThreeState="True" IsChecked="{x:Null}" Content="不确定" />
                                <CheckBox IsEnabled="False" Content="禁用" />
                                <CheckBox IsEnabled="False" IsChecked="True" Content="禁用选中" />
                            </StackPanel>

                            <!-- RadioButtons -->
                            <StackPanel Grid.Column="1" Spacing="12">
                                <TextBlock FontWeight="Bold" FontSize="12" Foreground="#888" Text="RADIO BUTTON" />
                                <RadioButton Content="单选 A" IsChecked="True" GroupName="DemoGroup" />
                                <RadioButton Content="单选 B" GroupName="DemoGroup" />
                                <RadioButton Content="单选 C" GroupName="DemoGroup" />
                                <RadioButton Content="单选 (禁用)" IsEnabled="False" />
                                <RadioButton Content="单选 (禁选)" IsEnabled="False" IsChecked="True" />
                            </StackPanel>

                            <!-- ToggleSwitches -->
                            <StackPanel Grid.Column="2" Spacing="12">
                                <TextBlock FontWeight="Bold" FontSize="12" Foreground="#888" Text="TOGGLE SWITCH" />
                                <ToggleSwitch Content="Wi-Fi" IsChecked="True" />
                                <ToggleSwitch Content="蓝牙" IsChecked="False" />
                                <ToggleSwitch Content="游戏模式" IsChecked="True" IsEnabled="False" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </card:Card>

                <!-- Section 4: Sliders & Text Input -->
                <card:Card 
                    Margin="10" 
                    Padding="24"
                    Background="White"
                    attachedProperties:Brutalization.IsBrutalized="True"
                    attachedProperties:Brutalization.BrutalizedShadows="6 6 0 0 #1A1918"
                    CornerRadius="12">
                    <StackPanel Spacing="16">
                        <TextBlock FontSize="20" FontWeight="Black" Foreground="#1A1918" Text="Slider &amp; TextBox" />
                        <Separator Height="1" Background="#1A1918" Opacity="0.2" />
                        
                        <Grid ColumnDefinitions="*,*">
                            <!-- TextBoxes and Sliders -->
                            <StackPanel Grid.Column="0" Spacing="14" Margin="0,0,10,0">
                                <TextBlock FontWeight="Bold" FontSize="12" Foreground="#888" Text="TEXT BOX (FOCUS POP-SHADOW)" />
                                <TextBox PlaceholderText="请输入文本..." />
                                <TextBox Text="具有新粗体黑框和彩色高亮阴影" />
                                <TextBox Text="禁用文本框演示" IsEnabled="False" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" Spacing="14" Margin="10,0,0,0">
                                <TextBlock FontWeight="Bold" FontSize="12" Foreground="#888" Text="SLIDER (CUSTOM KNOB SHADOW)" />
                                <Slider Value="40" Minimum="0" Maximum="100" />
                                <Slider Value="75" Minimum="0" Maximum="100" IsEnabled="False" />
                                <Grid ColumnDefinitions="*,*" Height="100">
                                    <Slider Value="50" IsDirectionReversed="True" Orientation="Vertical" Grid.Column="0" HorizontalAlignment="Center"/>
                                    <Slider Value="80" Orientation="Vertical" Grid.Column="1" HorizontalAlignment="Center"/>
                                </Grid>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </card:Card>

                <!-- Section 5: Complex Forms & Expanders (Menu, ToolTip, ComboBox, Expander) -->
                <card:Card 
                    Margin="10" 
                    Padding="24"
                    Background="White"
                    attachedProperties:Brutalization.IsBrutalized="True"
                    attachedProperties:Brutalization.BrutalizedShadows="6 6 0 0 #1A1918"
                    CornerRadius="12">
                    <StackPanel Spacing="16">
                        <TextBlock FontSize="20" FontWeight="Black" Foreground="#1A1918" Text="Popups &amp; Action Menus" />
                        <Separator Height="1" Background="#1A1918" Opacity="0.2" />
                        
                        <Grid ColumnDefinitions="*,*">
                            <StackPanel Grid.Column="0" Spacing="14">
                                <TextBlock FontWeight="Bold" FontSize="12" Foreground="#888" Text="MENU &amp; FLYOUTS" />
                                <Menu HorizontalAlignment="Left">
                                    <MenuItem Header="文件主题">
                                        <MenuItem Header="创建新文件" />
                                        <MenuItem Header="打开所在位置" />
                                        <Separator />
                                        <MenuItem Header="子层级偏好">
                                            <MenuItem Header="布鲁特黑暗配色" />
                                            <MenuItem Header="极简亮黄方案" />
                                        </MenuItem>
                                    </MenuItem>
                                    <MenuItem Header="编辑" />
                                </Menu>
                                
                                <Button Content="弹出式面板 Flyout" HorizontalAlignment="Left" Foreground="White" Background="{markupExtensions:ColorToken Name=Primary}">
                                    <Button.Flyout>
                                        <Flyout>
                                            <StackPanel Spacing="10" Width="200">
                                                <TextBlock Text="硬派 Flyout" FontWeight="Black" FontSize="16" />
                                                <TextBlock Text="这是一款带纯黑、硬质投影的酷炫弹出面板！它可以承载任意布局。" TextWrapping="Wrap" FontSize="12" />
                                                <Button Content="确认" HorizontalAlignment="Stretch" />
                                            </StackPanel>
                                        </Flyout>
                                    </Button.Flyout>
                                </Button>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Spacing="14" Margin="10,0,0,0">
                                <TextBlock FontWeight="Bold" FontSize="12" Foreground="#888" Text="COMBOBOX &amp; EXPANDER" />
                                <ComboBox SelectedIndex="0" HorizontalAlignment="Stretch">
                                    <ComboBoxItem>第一顺位超级可选项</ComboBoxItem>
                                    <ComboBoxItem>第二顺位普通可选项</ComboBoxItem>
                                    <ComboBoxItem>第三顺位终极备用可选项</ComboBoxItem>
                                </ComboBox>

                                <Expander Header="折叠信息模块 (Expander Header)" HorizontalAlignment="Stretch">
                                    <TextBlock Text="新布鲁特主义下的抽屉折叠信息更侧重于明显的分割边缘。" Height="40" TextWrapping="Wrap" />
                                </Expander>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </card:Card>

                <!-- Section 6: Action Status Indicators (ListBox, ToolTip & Progress) -->
                <card:Card 
                    Margin="10" 
                    Padding="24"
                    Background="White"
                    attachedProperties:Brutalization.IsBrutalized="True"
                    attachedProperties:Brutalization.BrutalizedShadows="6 6 0 0 #1A1918"
                    CornerRadius="12">
                    <StackPanel Spacing="16">
                        <TextBlock FontSize="20" FontWeight="Black" Foreground="#1A1918" Text="Action Status &amp; Progress" />
                        <Separator Height="1" Background="#1A1918" Opacity="0.2" />
                        
                        <Grid ColumnDefinitions="160,*">
                            <StackPanel Grid.Column="0" Spacing="8">
                                <TextBlock FontWeight="Bold" FontSize="12" Foreground="#888" Text="HARD CORE LISTBOX" />
                                <ListBox Height="140">
                                    <ListBoxItem Content="常规列表一" />
                                    <ListBoxItem Content="极简单选二" />
                                    <ListBoxItem Content="高级分类三" />
                                </ListBox>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Spacing="14" Margin="16,0,0,0">
                                <TextBlock FontWeight="Bold" FontSize="12" Foreground="#888" Text="PROGRESS INDICATORS (DETERMINATE)" />
                                <ProgressBar Value="35" Maximum="100" />
                                <ProgressBar Value="75" Maximum="100" ShowProgressText="True" Foreground="{markupExtensions:ColorToken Name=Secondary}"/>

                                <TextBlock FontWeight="Bold" FontSize="12" Foreground="#888" Text="PROGRESS STATIONS (INDETERMINATE)" />
                                <ProgressBar IsIndeterminate="True" Foreground="{markupExtensions:ColorToken Name=Primary}" />

                                <TextBlock FontWeight="Bold" FontSize="12" Foreground="#888" Text="TOOLTIP PREVIEW" />
                                <Border Background="#E6E6E3" Padding="8" CornerRadius="4" HorizontalAlignment="Left" ToolTip.Tip="这是一个经过新布鲁特主义高对比黄调设计的硬核 ToolTip！">
                                    <TextBlock Text="🖱 悬停在此处查看提示 ToolTip" FontSize="11" FontWeight="Bold" />
                                </Border>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </card:Card>

            </UniformGrid>
        </StackPanel>
    </ScrollViewer>
</Window>