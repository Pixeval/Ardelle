<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:buttons="clr-namespace:Pixeval.Controls.Ardelle.Controls.Buttons;assembly=Pixeval.Controls.Ardelle"
        xmlns:markupExtensions="clr-namespace:Pixeval.Controls.Ardelle.MarkupExtensions;assembly=Pixeval.Controls.Ardelle"
        xmlns:card="clr-namespace:Pixeval.Controls.Ardelle.Controls.Card;assembly=Pixeval.Controls.Ardelle"
        xmlns:attachedProperties="clr-namespace:Pixeval.Controls.Ardelle.AttachedProperties;assembly=Pixeval.Controls.Ardelle"
        x:CompileBindings="False"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="Pixeval.Controls.Ardelle.Demo.MainWindow"
        Title="Pixeval.Controls.Ardelle.Demo">
    <Grid RowDefinitions="Auto,*" RowSpacing="16" Margin="24">
        <card:Card attachedProperties:Brutalization.IsBrutalized="True" Width="500" Height="300" Background="{markupExtensions:ColorToken Name=Secondary}" HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Background="Red" Text="Brutalized Card" FontSize="24" Foreground="{markupExtensions:ColorToken Name=OnSecondary}" />
        </card:Card>
    </Grid>
</Window>
