<Window
    x:Class="Pixeval.Controls.Ardelle.Demo.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:attachedProperties="clr-namespace:Pixeval.Controls.Ardelle.AttachedProperties;assembly=Pixeval.Controls.Ardelle"
    xmlns:buttons="clr-namespace:Pixeval.Controls.Ardelle.Controls.Buttons;assembly=Pixeval.Controls.Ardelle"
    xmlns:card="clr-namespace:Pixeval.Controls.Ardelle.Controls.Card;assembly=Pixeval.Controls.Ardelle"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:markupExtensions="clr-namespace:Pixeval.Controls.Ardelle.MarkupExtensions;assembly=Pixeval.Controls.Ardelle"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    x:CompileBindings="False"
    Title="Pixeval Ardelle Neobrutalism UI Showcase"
    Width="1200"
    Height="900"
    Background="{DynamicResource DemoPageBackgroundBrush}"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">

    <Window.Resources>
        <SolidColorBrush x:Key="DemoPageBackgroundBrush" Color="#F4F4F3" />
        <SolidColorBrush x:Key="DemoCardBackgroundBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="DemoCardForegroundBrush" Color="#1A1918" />
        <SolidColorBrush x:Key="DemoMutedForegroundBrush" Color="#888888" />
        <SolidColorBrush x:Key="DemoSeparatorBrush" Color="#1A1918" />
        <SolidColorBrush x:Key="DemoAltSurfaceBrush" Color="#E6E6E3" />
    </Window.Resources>

    <ScrollViewer x:Name="DemoScrollViewer" VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="30" Spacing="30">

            <Border
                Margin="0,0,8,8"
                Padding="18"
                attachedProperties:Brutalization.BrutalizedShadows="6 6 0 0 #1A1918"
                attachedProperties:Brutalization.IsBrutalized="True"
                Background="{DynamicResource DemoCardBackgroundBrush}"
                CornerRadius="12">
                <DockPanel LastChildFill="False">
                    <StackPanel Spacing="4">
                        <TextBlock
                            FontSize="18"
                            FontWeight="Black"
                            Foreground="{DynamicResource DemoCardForegroundBrush}"
                            Text="Demo Theme" />
                        <TextBlock
                            FontSize="12"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource DemoMutedForegroundBrush}"
                            Text="切换 Demo 页面明暗模式，预览组件在浅色与深色舞台中的表现。" />
                    </StackPanel>

                    <StackPanel
                        x:Name="ThemeModePanel"
                        VerticalAlignment="Center"
                        DockPanel.Dock="Right"
                        Orientation="Horizontal"
                        Spacing="10">
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="12"
                            FontWeight="Bold"
                            Foreground="{DynamicResource DemoMutedForegroundBrush}"
                            Text="Dark Mode" />
                        <ToggleSwitch
                            x:Name="ThemeModeSwitch"
                            VerticalAlignment="Center"
                            IsCheckedChanged="ThemeModeSwitch_OnIsCheckedChanged" />
                    </StackPanel>
                </DockPanel>
            </Border>

            <!--  Header Banner  -->
            <Border
                Margin="0,0,8,8"
                Padding="30"
                attachedProperties:Brutalization.BrutalizedShadows="8 8 0 0 #1A1918"
                attachedProperties:Brutalization.IsBrutalized="True"
                Background="{markupExtensions:ColorToken Name=Primary}"
                BorderBrush="#1A1918"
                BorderThickness="3"
                CornerRadius="16">
                <StackPanel Spacing="10">
                    <TextBlock
                        FontSize="36"
                        FontWeight="Black"
                        Foreground="White"
                        Text="Ardelle Neobrutalism + Material Gallery" />
                    <TextBlock
                        FontSize="16"
                        FontWeight="SemiBold"
                        Foreground="White"
                        Opacity="0.9"
                        Text="精心呈现的混合设计语言库组件展示，融入高对比度、硬阴影、扁平质感与灵动微动效。" />
                </StackPanel>
            </Border>

            <!--  CommandBar Header (NeoBrutalist style)  -->
            <CommandBar Margin="0,0,4,4" DefaultLabelPosition="Collapsed">
                <CommandBarButton Icon="{markupExtensions:SymbolIcon Save}" Label="新建" />
                <CommandBarButton Icon="{markupExtensions:SymbolIcon Save}" Label="保存" />
                <CommandBarSeparator />
                <CommandBarToggleButton
                    Icon="{markupExtensions:SymbolIcon Save}"
                    IsChecked="True"
                    Label="突出显示" />
                <CommandBar.SecondaryCommands>
                    <CommandBarButton Icon="{markupExtensions:SymbolIcon Save}" Label="新建" />
                    <CommandBarButton Icon="{markupExtensions:SymbolIcon Save}" Label="保存" />
                    <CommandBarSeparator />
                    <CommandBarToggleButton
                        Icon="{markupExtensions:SymbolIcon Save}"
                        IsChecked="True"
                        Label="长长长长长长长长长长长长长长长长长长" />
                </CommandBar.SecondaryCommands>
            </CommandBar>

            <!--  Grid Layout of Showcase Panels  -->
            <UniformGrid HorizontalAlignment="Stretch" Columns="2">

                <!--  Section 1: Buttons  -->
                <card:Card
                    Margin="10"
                    Padding="24"
                    attachedProperties:Brutalization.BrutalizedShadows="6 6 0 0 #1A1918"
                    attachedProperties:Brutalization.IsBrutalized="True"
                    Background="{DynamicResource DemoCardBackgroundBrush}"
                    CornerRadius="12">
                    <StackPanel Spacing="16">
                        <TextBlock
                            FontSize="20"
                            FontWeight="Black"
                            Foreground="{DynamicResource DemoCardForegroundBrush}"
                            Text="Action &amp; Standard Buttons" />
                        <Separator
                            Height="1"
                            Background="{DynamicResource DemoSeparatorBrush}"
                            Opacity="0.2" />

                        <WrapPanel
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Orientation="Horizontal">
                            <StackPanel Margin="10" Spacing="12">
                                <TextBlock
                                    FontSize="12"
                                    FontWeight="Bold"
                                    Foreground="{DynamicResource DemoMutedForegroundBrush}"
                                    Text="NEOBRUTALISM ACTIONS" />
                                <buttons:ActionButton Background="{markupExtensions:ColorToken Name=Primary}" Content="Action Push" />
                                <buttons:ActionIconButton
                                    Background="{markupExtensions:ColorToken Name=Secondary}"
                                    Content="Save Action"
                                    Icon="{markupExtensions:SymbolIcon Save}" />
                            </StackPanel>

                            <StackPanel Margin="10" Spacing="12">
                                <TextBlock
                                    FontSize="12"
                                    FontWeight="Bold"
                                    Foreground="{DynamicResource DemoMutedForegroundBrush}"
                                    Text="STANDARD / OUTLINE" />
                                <buttons:Button Background="{markupExtensions:ColorToken Name=Secondary}" Content="Flat Solid" />
                                <buttons:OutlineButton Content="Outline Button" />
                                <buttons:GhostButton Content="Ghost Button" />
                            </StackPanel>
                        </WrapPanel>
                    </StackPanel>
                </card:Card>

                <!--  Section 2: TabControl & Highlighting Views  -->
                <card:Card
                    Margin="10"
                    Padding="24"
                    attachedProperties:Brutalization.BrutalizedShadows="6 6 0 0 #1A1918"
                    attachedProperties:Brutalization.IsBrutalized="True"
                    Background="{DynamicResource DemoCardBackgroundBrush}"
                    CornerRadius="12">
                    <StackPanel Spacing="16">
                        <TextBlock
                            FontSize="20"
                            FontWeight="Black"
                            Foreground="{DynamicResource DemoCardForegroundBrush}"
                            Text="Brutalist File Folder View (TabControl)" />
                        <Separator
                            Height="1"
                            Background="{DynamicResource DemoSeparatorBrush}"
                            Opacity="0.2" />

                        <TabControl Height="180">
                            <TabItem Header="文件一">
                                <StackPanel Margin="15" Spacing="8">
                                    <TextBlock
                                        FontSize="16"
                                        FontWeight="Black"
                                        Text="极简新现代主义" />
                                    <TextBlock
                                        FontSize="13"
                                        Text="此选卡经过重写，其页签模仿真实的档案文件夹，在选中时获得富有视觉冲击力的主题高亮色。"
                                        TextWrapping="Wrap" />
                                </StackPanel>
                            </TabItem>
                            <TabItem Header="设置二">
                                <StackPanel Margin="15" Spacing="8">
                                    <TextBlock
                                        FontSize="16"
                                        FontWeight="Black"
                                        Text="选项卡 B 界面" />
                                    <TextBlock
                                        FontSize="13"
                                        Text="任何放置在 TabItem 中的视图都会无缝融合在底下的新布鲁重构卡上。"
                                        TextWrapping="Wrap" />
                                </StackPanel>
                            </TabItem>
                            <TabItem Header="已锁定页" IsEnabled="False" />
                        </TabControl>
                    </StackPanel>
                </card:Card>

                <!--  Section 3: Selection controls (CheckBox, Radio, Switch)  -->
                <card:Card
                    Margin="10"
                    Padding="24"
                    attachedProperties:Brutalization.BrutalizedShadows="6 6 0 0 #1A1918"
                    attachedProperties:Brutalization.IsBrutalized="True"
                    Background="{DynamicResource DemoCardBackgroundBrush}"
                    CornerRadius="12">
                    <StackPanel Spacing="16">
                        <TextBlock
                            FontSize="20"
                            FontWeight="Black"
                            Foreground="{DynamicResource DemoCardForegroundBrush}"
                            Text="Selection Controls" />
                        <Separator
                            Height="1"
                            Background="{DynamicResource DemoSeparatorBrush}"
                            Opacity="0.2" />

                        <Grid ColumnDefinitions="*,*,*">
                            <!--  CheckBoxes  -->
                            <StackPanel Grid.Column="0" Spacing="12">
                                <TextBlock
                                    FontSize="12"
                                    FontWeight="Bold"
                                    Foreground="{DynamicResource DemoMutedForegroundBrush}"
                                    Text="CHECKBOX" />
                                <CheckBox Content="未选中" />
                                <CheckBox Content="选中" IsChecked="True" />
                                <CheckBox
                                    Content="不确定"
                                    IsChecked="{x:Null}"
                                    IsThreeState="True" />
                                <CheckBox Content="禁用" IsEnabled="False" />
                                <CheckBox
                                    Content="禁用选中"
                                    IsChecked="True"
                                    IsEnabled="False" />
                            </StackPanel>

                            <!--  RadioButtons  -->
                            <StackPanel Grid.Column="1" Spacing="12">
                                <TextBlock
                                    FontSize="12"
                                    FontWeight="Bold"
                                    Foreground="{DynamicResource DemoMutedForegroundBrush}"
                                    Text="RADIO BUTTON" />
                                <RadioButton
                                    Content="单选 A"
                                    GroupName="DemoGroup"
                                    IsChecked="True" />
                                <RadioButton Content="单选 B" GroupName="DemoGroup" />
                                <RadioButton Content="单选 C" GroupName="DemoGroup" />
                                <RadioButton Content="单选 (禁用)" IsEnabled="False" />
                                <RadioButton
                                    Content="单选 (禁选)"
                                    IsChecked="True"
                                    IsEnabled="False" />
                            </StackPanel>

                            <!--  ToggleSwitches  -->
                            <StackPanel Grid.Column="2" Spacing="12">
                                <TextBlock
                                    FontSize="12"
                                    FontWeight="Bold"
                                    Foreground="{DynamicResource DemoMutedForegroundBrush}"
                                    Text="TOGGLE SWITCH" />
                                <ToggleSwitch Content="Wi-Fi" IsChecked="True" />
                                <ToggleSwitch Content="蓝牙" IsChecked="False" />
                                <ToggleSwitch
                                    Content="游戏模式"
                                    IsChecked="True"
                                    IsEnabled="False" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </card:Card>

                <!--  Section 4: Sliders & Text Input  -->
                <card:Card
                    Margin="10"
                    Padding="24"
                    attachedProperties:Brutalization.BrutalizedShadows="6 6 0 0 #1A1918"
                    attachedProperties:Brutalization.IsBrutalized="True"
                    Background="{DynamicResource DemoCardBackgroundBrush}"
                    CornerRadius="12">
                    <StackPanel Spacing="16">
                        <TextBlock
                            FontSize="20"
                            FontWeight="Black"
                            Foreground="{DynamicResource DemoCardForegroundBrush}"
                            Text="Slider &amp; TextBox" />
                        <Separator
                            Height="1"
                            Background="{DynamicResource DemoSeparatorBrush}"
                            Opacity="0.2" />

                        <Grid ColumnDefinitions="*,*">
                            <!--  TextBoxes and Sliders  -->
                            <StackPanel
                                Grid.Column="0"
                                Margin="0,0,10,0"
                                Spacing="14">
                                <TextBlock
                                    FontSize="12"
                                    FontWeight="Bold"
                                    Foreground="{DynamicResource DemoMutedForegroundBrush}"
                                    Text="TEXT BOX (FOCUS POP-SHADOW)" />
                                <TextBox PlaceholderText="请输入文本..." />
                                <TextBox Text="具有新粗体黑框和彩色高亮阴影" />
                                <TextBox IsEnabled="False" Text="禁用文本框演示" />
                            </StackPanel>

                            <StackPanel
                                Grid.Column="1"
                                Margin="10,0,0,0"
                                Spacing="14">
                                <TextBlock
                                    FontSize="12"
                                    FontWeight="Bold"
                                    Foreground="{DynamicResource DemoMutedForegroundBrush}"
                                    Text="SLIDER (CUSTOM KNOB SHADOW)" />
                                <Slider
                                    Maximum="100"
                                    Minimum="0"
                                    Value="40" />
                                <Slider
                                    IsEnabled="False"
                                    Maximum="100"
                                    Minimum="0"
                                    Value="75" />
                                <Grid Height="100" ColumnDefinitions="*,*">
                                    <Slider
                                        Grid.Column="0"
                                        HorizontalAlignment="Center"
                                        IsDirectionReversed="True"
                                        Orientation="Vertical"
                                        Value="50" />
                                    <Slider
                                        Grid.Column="1"
                                        HorizontalAlignment="Center"
                                        Orientation="Vertical"
                                        Value="80" />
                                </Grid>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </card:Card>

                <!--  Section 5: Complex Forms & Expanders (Menu, ToolTip, ComboBox, Expander)  -->
                <card:Card
                    Margin="10"
                    Padding="24"
                    attachedProperties:Brutalization.BrutalizedShadows="6 6 0 0 #1A1918"
                    attachedProperties:Brutalization.IsBrutalized="True"
                    Background="{DynamicResource DemoCardBackgroundBrush}"
                    CornerRadius="12">
                    <StackPanel Spacing="16">
                        <TextBlock
                            FontSize="20"
                            FontWeight="Black"
                            Foreground="{DynamicResource DemoCardForegroundBrush}"
                            Text="Popups &amp; Action Menus" />
                        <Separator
                            Height="1"
                            Background="{DynamicResource DemoSeparatorBrush}"
                            Opacity="0.2" />

                        <Grid ColumnDefinitions="*,*">
                            <StackPanel Grid.Column="0" Spacing="14">
                                <TextBlock
                                    FontSize="12"
                                    FontWeight="Bold"
                                    Foreground="{DynamicResource DemoMutedForegroundBrush}"
                                    Text="MENU &amp; FLYOUTS" />
                                <Menu HorizontalAlignment="Left">
                                    <MenuItem Header="文件主题">
                                        <MenuItem Header="创建新文件" />
                                        <MenuItem Header="打开所在位置" />
                                        <Separator />
                                        <MenuItem Header="子层级偏好">
                                            <MenuItem Header="布鲁特黑暗配色" />
                                            <MenuItem Header="极简亮黄方案" />
                                        </MenuItem>
                                    </MenuItem>
                                    <MenuItem Header="编辑" />
                                </Menu>

                                <Button
                                    HorizontalAlignment="Left"
                                    Background="{markupExtensions:ColorToken Name=Primary}"
                                    Content="弹出式面板 Flyout"
                                    Foreground="White">
                                    <Button.Flyout>
                                        <Flyout>
                                            <StackPanel Width="200" Spacing="10">
                                                <TextBlock
                                                    FontSize="16"
                                                    FontWeight="Black"
                                                    Text="硬派 Flyout" />
                                                <TextBlock
                                                    FontSize="12"
                                                    Text="这是一款带纯黑、硬质投影的酷炫弹出面板！它可以承载任意布局。"
                                                    TextWrapping="Wrap" />
                                                <Button HorizontalAlignment="Stretch" Content="确认" />
                                            </StackPanel>
                                        </Flyout>
                                    </Button.Flyout>
                                </Button>
                            </StackPanel>

                            <StackPanel
                                Grid.Column="1"
                                Margin="10,0,0,0"
                                Spacing="14">
                                <TextBlock
                                    FontSize="12"
                                    FontWeight="Bold"
                                    Foreground="{DynamicResource DemoMutedForegroundBrush}"
                                    Text="COMBOBOX &amp; EXPANDER" />
                                <ComboBox HorizontalAlignment="Stretch" SelectedIndex="0">
                                    <ComboBoxItem>第一顺位超级可选项</ComboBoxItem>
                                    <ComboBoxItem>第二顺位普通可选项</ComboBoxItem>
                                    <ComboBoxItem>第三顺位终极备用可选项</ComboBoxItem>
                                </ComboBox>

                                <Expander HorizontalAlignment="Stretch" Header="折叠信息模块 (Expander Header)">
                                    <TextBlock
                                        Height="40"
                                        Text="新布鲁特主义下的抽屉折叠信息更侧重于明显的分割边缘。"
                                        TextWrapping="Wrap" />
                                </Expander>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </card:Card>

                <!--  Section 6: Action Status Indicators (ListBox, ToolTip & Progress)  -->
                <card:Card
                    Margin="10"
                    Padding="24"
                    attachedProperties:Brutalization.BrutalizedShadows="6 6 0 0 #1A1918"
                    attachedProperties:Brutalization.IsBrutalized="True"
                    Background="{DynamicResource DemoCardBackgroundBrush}"
                    CornerRadius="12">
                    <StackPanel Spacing="16">
                        <TextBlock
                            FontSize="20"
                            FontWeight="Black"
                            Foreground="{DynamicResource DemoCardForegroundBrush}"
                            Text="Action Status &amp; Progress" />
                        <Separator
                            Height="1"
                            Background="{DynamicResource DemoSeparatorBrush}"
                            Opacity="0.2" />

                        <Grid ColumnDefinitions="160,*">
                            <StackPanel Grid.Column="0" Spacing="8">
                                <TextBlock
                                    FontSize="12"
                                    FontWeight="Bold"
                                    Foreground="{DynamicResource DemoMutedForegroundBrush}"
                                    Text="HARD CORE LISTBOX" />
                                <ListBox Height="140">
                                    <ListBoxItem Content="常规列表一" />
                                    <ListBoxItem Content="极简单选二" />
                                    <ListBoxItem Content="高级分类三" />
                                </ListBox>
                            </StackPanel>

                            <StackPanel
                                Grid.Column="1"
                                Margin="16,0,0,0"
                                Spacing="14">
                                <TextBlock
                                    FontSize="12"
                                    FontWeight="Bold"
                                    Foreground="{DynamicResource DemoMutedForegroundBrush}"
                                    Text="PROGRESS INDICATORS (DETERMINATE)" />
                                <ProgressBar Maximum="100" Value="35" />
                                <ProgressBar
                                    Foreground="{markupExtensions:ColorToken Name=Secondary}"
                                    Maximum="100"
                                    ShowProgressText="True"
                                    Value="75" />

                                <TextBlock
                                    FontSize="12"
                                    FontWeight="Bold"
                                    Foreground="{DynamicResource DemoMutedForegroundBrush}"
                                    Text="PROGRESS STATIONS (INDETERMINATE)" />
                                <ProgressBar Foreground="{markupExtensions:ColorToken Name=Primary}" IsIndeterminate="True" />

                                <TextBlock
                                    FontSize="12"
                                    FontWeight="Bold"
                                    Foreground="{DynamicResource DemoMutedForegroundBrush}"
                                    Text="TOOLTIP PREVIEW" />
                                <Border
                                    Padding="8"
                                    HorizontalAlignment="Left"
                                    Background="{DynamicResource DemoAltSurfaceBrush}"
                                    CornerRadius="4"
                                    ToolTip.Tip="这是一个经过新布鲁特主义高对比黄调设计的硬核 ToolTip！">
                                    <TextBlock
                                        FontSize="11"
                                        FontWeight="Bold"
                                        Text="🖱 悬停在此处查看提示 ToolTip" />
                                </Border>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </card:Card>

            </UniformGrid>
        </StackPanel>
    </ScrollViewer>
</Window>
